{
  "manifest_version": 3,
  "name": "Telegram Video Downloader",
  "version": "2.4.3",
  "description": "Download videos from Telegram Web (K and A versions)",
  "permissions": ["scripting"],
  "host_permissions": ["https://web.telegram.org/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://web.telegram.org/*"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
